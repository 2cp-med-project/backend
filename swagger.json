{
  "definition": {
    "openapi": "3.0.0",
    "info": {
      "title": "Medical Access API",
      "version": "1.0.0",
      "description": "Doctor - Patient Medical Platform with Access Control"
    },
    "servers": [
      {
        "url": "http://localhost:5000/api"
      }
    ],
    "components": {
      "securitySchemes": {
        "bearerAuth": {
          "type": "http",
          "scheme": "bearer",
          "bearerFormat": "JWT"
        }
      }
    },
    "security": [
      {
        "bearerAuth": []
      }
    ],
    "paths": {
      "/auth/register/doctor": {
        "post": {
          "tags": ["Auth"],
          "summary": "Register new doctor",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["firstName", "lastName", "email", "password", "licenseNumber"],
                  "properties": {
                    "firstName": { "type": "string" },
                    "lastName": { "type": "string" },
                    "email": { "type": "string" },
                    "password": { "type": "string" },
                    "specialization": { "type": "string" },
                    "licenseNumber": { "type": "string" },
                    "phone": { "type": "string" },
                    "cabinetAddress": { "type": "string" }
                  }
                }
              }
            }
          },
          "responses": {
            "201": { "description": "Doctor registered successfully" }
          }
        }
      },

      "/auth/register/patient": {
        "post": {
          "tags": ["Auth"],
          "summary": "Register new patient",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["firstName", "lastName", "email", "password"],
                  "properties": {
                    "firstName": { "type": "string" },
                    "lastName": { "type": "string" },
                    "email": { "type": "string" },
                    "password": { "type": "string" },
                    "dateOfBirth": { "type": "string", "format": "date" },
                    "gender": { "type": "string", "enum": ["male", "female"] },
                    "phone": { "type": "string" },
                    "address": { "type": "string" }
                  }
                }
              }
            }
          },
          "responses": {
            "201": { "description": "Patient registered successfully" }
          }
        }
      },

      "/auth/login": {
        "post": {
          "tags": ["Auth"],
          "summary": "Login (Doctor or Patient)",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["email", "password"],
                  "properties": {
                    "email": { "type": "string" },
                    "password": { "type": "string" }
                  }
                }
              }
            }
          },
          "responses": {
            "200": { "description": "Login successful (returns JWT token)" }
          }
        }
      },

      "/access/request": {
        "post": {
          "tags": ["Access"],
          "summary": "Doctor requests access to patient",
          "security": [{ "bearerAuth": [] }],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "patientId": { "type": "string" }
                  }
                }
              }
            }
          },
          "responses": {
            "200": { "description": "Access request sent" }
          }
        }
      },

      "/access/patient/requests": {
        "get": {
          "tags": ["Access"],
          "summary": "Patient gets pending access requests",
          "security": [{ "bearerAuth": [] }],
          "responses": {
            "200": { "description": "List of pending access requests" }
          }
        }
      },

      "/access/{id}/respond": {
        "put": {
          "tags": ["Access"],
          "summary": "Patient approves or rejects doctor request",
          "security": [{ "bearerAuth": [] }],
          "parameters": [
            {
              "in": "path",
              "name": "id",
              "required": true,
              "schema": { "type": "string" }
            }
          ],
          "requestBody": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": ["approved", "rejected"]
                    }
                  }
                }
              }
            }
          },
          "responses": {
            "200": { "description": "Access updated" }
          }
        }
      },

      "/records": {
        "post": {
          "tags": ["Records"],
          "summary": "Doctor adds medical record",
          "security": [{ "bearerAuth": [] }],
          "responses": {
            "201": { "description": "Record created" }
          }
        }
      },

      "/records/patient": {
        "get": {
          "tags": ["Records"],
          "summary": "Patient views own medical records",
          "security": [{ "bearerAuth": [] }],
          "responses": {
            "200": { "description": "List of medical records" }
          }
        }
      },

      "/notifications": {
        "get": {
          "tags": ["Notifications"],
          "summary": "User gets notifications",
          "security": [{ "bearerAuth": [] }],
          "responses": {
            "200": { "description": "List of notifications" }
          }
        }
      }
    }
  },

  "apis": []
}