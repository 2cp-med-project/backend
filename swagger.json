						"in": "query",
						"schema": {
							"type": "integer"
						}
					},
					{
						"name": "limit",
						"description": "Number of items per page",
						"default": 10,
						"in": "query",
						"schema": {
							"type": "integer"
						}
					},
					{
						"name": "order",
						"description": "Sort order (asc or desc)",
						"default": "asc",
						"in": "query",
						"schema": {
							"type": "string"
						}
					},
					{
						"name": "sortBy",
						"description": "Field to sort by",
						"default": "firstName",
						"in": "query",
						"schema": {
							"type": "string"
						}
					}
				],
				"responses": {
					"200": { "description": "OK" },
