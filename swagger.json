{
  "definition": {
    "openapi": "3.0.0",
    "info": {
      "title": "Medical Access API",
      "version": "1.0.0",
      "description": "Doctor - Patient Medical Platform with Access Control"
    },
    "servers": [
      {
        "url": "http://localhost:5000/api-docs"
      }
    ],
    "paths": {
      "/auth/register/doctor": {
        "post": {
          "tags": ["Auth"],
          "summary": "Register a user",
          "description": "Register a new patient or doctor.",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterUser"
                }
              }
            }
          },
          "responses": {
            "201": {
              "description": "User registered successfully."
            },
            "400": {
              "description": "Validation error."
            }
          }
        }
      },
      "/auth/login": {
        "post": {
          "tags": ["Auth"],
          "summary": "Login",
          "description": "Authenticate user and return token.",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginUser"
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "Login successful."
            },
            "401": {
              "description": "Invalid credentials."
            }
          }
        }
      },
      "/auth/logout": {
        "post": {
          "tags": ["Auth"],
          "summary": "Logout",
          "description": "Log out the current user and invalidate the session.",
          "responses": {
            "200": {
              "description": "Logged out successfully."
            }
          }
        }
      },
      "/auth/refresh-token": {
        "post": {
          "tags": ["Auth"],
          "summary": "Refresh access token",
          "description": "Issue a new access token using a refresh token.",
          "responses": {
            "200": {
              "description": "Token refreshed successfully."
            },
            "401": {
              "description": "Invalid or expired refresh token."
            }
          }
        }
      },
      "/auth/verify-otp": {
        "post": {
          "tags": ["Auth"],
          "summary": "Verify OTP",
          "description": "Verify a one-time password sent to the user.",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "email": {
                      "type": "string"
                    },
                    "otp": {
                      "type": "string"
                    }
                  },
                  "required": ["email", "otp"]
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "OTP verified successfully."
            },
            "400": {
              "description": "Invalid or expired OTP."
            }
          }
        }
      },
      "/users/patients": {
        "get": {
          "tags": ["Users"],
          "summary": "List all patients",
          "description": "Retrieve a list of all patients.",
          "responses": {
            "200": {
              "description": "List of patients",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/Patient"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "/patients/{id}": {
        "get": {
          "tags": ["Users"],
          "summary": "Get patient profile",
          "parameters": [
            {
              "name": "id",
              "in": "path",
              "required": true,
              "schema": {
                "type": "string"
              }
            }
          ],
          "responses": {
            "200": {
              "description": "Patient profile",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/Patient"
                  }
                }
              }
            },
            "404": {
              "description": "Patient not found."
            }
          }
        }
      },
      "/doctors": {
        "get": {
          "tags": ["Users"],
          "summary": "List all doctors",
          "responses": {
            "200": {
              "description": "List of doctors",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/Doctor"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "/records/consultation": {
        "post": {
          "tags": ["Consultations"],
          "summary": "Create a consultation",
          "description": "Create a new consultation record for a patient.",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConsultationInput"
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "Consultation created, returns the consultation ID.",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "string",
                    "example": "665a1f2e3c4b5d6e7f8a9b0c"
                  }
                }
              }
            },
            "400": {
              "description": "Validation error."
            }
          }
        }
      },
      "/records/consultation/{id}": {
        "get": {
          "tags": ["Consultations"],
          "summary": "Get a consultation by ID",
          "description": "Retrieve a single consultation by its ID.",
          "parameters": [
            {
              "name": "id",
              "in": "path",
              "required": true,
              "schema": {
                "type": "string"
              }
            }
          ],
          "responses": {
            "200": {
              "description": "Consultation found",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/Consultation"
                  }
                }
              }
            },
            "404": {
              "description": "Consultation not found."
            },
            "400": {
              "description": "Bad request."
            }
          }
        },
        "patch": {
          "tags": ["Consultations"],
          "summary": "Update a consultation",
          "description": "Partially update an existing consultation by its ID.",
          "parameters": [
            {
              "name": "id",
              "in": "path",
              "required": true,
              "schema": {
                "type": "string"
              }
            }
          ],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConsultationInput"
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "Consultation updated",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/Consultation"
                  }
                }
              }
            },
            "404": {
              "description": "Consultation not found."
            },
            "400": {
              "description": "Validation error."
            }
          }
        },
        "delete": {
          "tags": ["Consultations"],
          "summary": "Delete a consultation",
          "description": "Delete a consultation by its ID.",
          "parameters": [
            {
              "name": "id",
              "in": "path",
              "required": true,
              "schema": {
                "type": "string"
              }
            }
          ],
          "responses": {
            "200": {
              "description": "Consultation deleted successfully."
            },
            "404": {
              "description": "Consultation not found."
            },
            "400": {
              "description": "Bad request."
            }
          }
        }
      },
      "/records/consultations/{patientId}": {
        "get": {
          "tags": ["Consultations"],
          "summary": "List consultations for a patient",
          "description": "Retrieve a paginated, sortable list of consultations for a given patient.",
          "parameters": [
            {
              "name": "patientId",
              "in": "path",
              "required": true,
              "schema": {
                "type": "string"
              }
            },
            {
              "name": "page",
              "in": "query",
              "required": false,
              "description": "Page number (0-based). Defaults to 0.",
              "schema": {
                "type": "integer",
                "default": 0
              }
            },
            {
              "name": "limit",
              "in": "query",
              "required": false,
              "description": "Number of results per page. Defaults to 10.",
              "schema": {
                "type": "integer",
                "default": 10
              }
            },
            {
              "name": "sortBy",
              "in": "query",
              "required": false,
              "description": "Field to sort by. Defaults to 'date'.",
              "schema": {
                "type": "string",
                "default": "date"
              }
            },
            {
              "name": "order",
              "in": "query",
              "required": false,
              "description": "Sort order: 'asc' or 'desc'. Defaults to 'desc'.",
              "schema": {
                "type": "string",
                "enum": ["asc", "desc"],
                "default": "desc"
              }
            }
          ],
          "responses": {
            "200": {
              "description": "Paginated list of consultations",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/Consultation"
                    }
                  }
                }
              }
            },
            "400": {
              "description": "Invalid sort field or sort order."
            }
          }
        }
      },
      "/medical-card/scan/{cardId}": {
        "get": {
          "tags": ["Medical Card"],
          "summary": "Scan digital health card",
          "parameters": [
            {
              "name": "cardId",
              "in": "path",
              "required": true,
              "schema": {
                "type": "string"
              }
            }
          ],
          "responses": {
            "200": {
              "description": "Patient data retrieved",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/MedicalCardResponse"
                  }
                }
              }
            },
            "404": {
              "description": "Card not found."
            }
          }
        }
      },
      "/ai/specialty": {
        "post": {
          "tags": ["AI"],
          "summary": "AI — Recommend medical specialty",
          "description": "Send symptoms and receive predicted specialty.",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SymptomRequest"
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "Specialty predicted",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/SpecialtyPrediction"
                  }
                }
              }
            }
          }
        }
      }
    },
    "components": {
      "schemas": {
        "RegisterUser": {
          "type": "object",
          "properties": {
            "role": {
              "type": "string",
              "enum": ["patient", "doctor"]
            },
            "fullName": {
              "type": "string"
            },
            "email": {
              "type": "string"
            },
            "password": {
              "type": "string"
            },
            "specialty": {
              "type": "string"
            },
            "location": {
              "type": "string"
            }
          },
          "required": ["role", "email", "password"]
        },
        "LoginUser": {
          "type": "object",
          "properties": {
            "email": {
              "type": "string"
            },
            "password": {
              "type": "string"
            }
          },
          "required": ["email", "password"]
        },
        "Patient": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "firstName": {
              "type": "string"
            },
            "lastName": {
              "type": "string"
            },
            "email": {
              "type": "string"
            },
            "dateOfBirth": {
              "type": "string",
              "format": "date"
            },
            "placeOfBirth": {
              "type": "string"
            },
            "gender": {
              "type": "string",
              "enum": ["male", "female"]
            },
            "phone": {
              "type": "string"
            },
            "address": {
              "type": "string"
            },
            "medicalResume": {
              "type": "string"
            },
            "cardQRCode": {
              "type": "string"
            }
          }
        },
        "Doctor": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "firstName": {
              "type": "string"
            },
            "lastName": {
              "type": "string"
            },
            "email": {
              "type": "string"
            },
            "specialization": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "licenseNumber": {
              "type": "string"
            },
            "cabinetAddress": {
              "type": "string"
            }
          }
        },
        "ConsultationInput": {
          "type": "object",
          "properties": {
            "doctorId": {
              "type": "string",
              "description": "Doctor ObjectId"
            },
            "patientId": {
              "type": "string",
              "description": "Patient ObjectId"
            },
            "date": {
              "type": "string",
              "format": "date-time"
            },
            "status": {
              "type": "string",
              "enum": ["scheduled", "completed", "cancelled"]
            },
            "typeofvisit": {
              "type": "string"
            },
            "motive": {
              "type": "string"
            },
            "symptoms": {
              "type": "string"
            },
            "severity": {
              "type": "string",
              "enum": ["mild", "moderate", "severe"]
            },
            "followUpDate": {
              "type": "string",
              "format": "date-time"
            },
            "diagnosis": {
              "type": "string"
            },
            "treatmentPlan": {
              "type": "string"
            },
            "notes": {
              "type": "string"
            },
            "bloodPressure": {
              "type": "string"
            },
            "heartRate": {
              "type": "string"
            },
            "respiratoryRate": {
              "type": "string"
            },
            "temperature": {
              "type": "string"
            },
            "weight": {
              "type": "string"
            },
            "systemReview": {
              "type": "string"
            },
            "additionalTests": {
              "type": "string"
            }
          },
          "required": ["doctorId", "patientId", "date"]
        },
        "Consultation": {
          "type": "object",
          "properties": {
            "_id": {
              "type": "string"
            },
            "doctor": {
              "type": "string",
              "description": "Doctor ObjectId"
            },
            "patient": {
              "type": "string",
              "description": "Patient ObjectId"
            },
            "date": {
              "type": "string",
              "format": "date-time"
            },
            "status": {
              "type": "string",
              "enum": ["scheduled", "completed", "cancelled"]
            },
            "typeofvisit": {
              "type": "string"
            },
            "motive": {
              "type": "string"
            },
            "symptoms": {
              "type": "string"
            },
            "severity": {
              "type": "string",
              "enum": ["mild", "moderate", "severe"]
            },
            "followUpDate": {
              "type": "string",
              "format": "date-time"
            },
            "diagnosis": {
              "type": "string"
            },
            "treatmentPlan": {
              "type": "string"
            },
            "notes": {
              "type": "string"
            },
            "bloodPressure": {
              "type": "string"
            },
            "heartRate": {
              "type": "string"
            },
            "respiratoryRate": {
              "type": "string"
            },
            "temperature": {
              "type": "string"
            },
            "weight": {
              "type": "string"
            },
            "systemReview": {
              "type": "string"
            },
            "additionalTests": {
              "type": "string"
            },
            "attachments": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "MedicalCardResponse": {
          "type": "object",
          "properties": {
            "patientId": {
              "type": "string"
            },
            "fullName": {
              "type": "string"
            },
            "age": {
              "type": "number"
            },
            "medicalHistory": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "SymptomRequest": {
          "type": "object",
          "properties": {
            "symptoms": {
              "type": "string"
            }
          },
          "required": ["symptoms"]
        },
        "SpecialtyPrediction": {
          "type": "object",
          "properties": {
            "predictedSpecialty": {
              "type": "string"
            },
            "confidence": {
              "type": "number"
            }
          }
        }
      }
    }
  },
  "apis": ["./src/modules/**/routes.js"]
}
