					"200": { "description": "OK" },
					"400": { "description": "Bad Request" },
					"500": { "description": "Internal Server Error" }
				},
				"security": [
					{
						"BearerAuth": []
					}
				]
			}
		},
		"/api/records/consultation": {
			"post": {
				"tags": ["Consultations"],
				"summary": "Create a new consultation record",
				"description": "Roles: doctor. only doctors who have access to the patient can create consultations for that patient",
				"responses": {
					"201": { "description": "Created" },
					"400": { "description": "Bad Request" },
					"403": { "description": "Forbidden" },
					"404": { "description": "Not Found" },
					"500": { "description": "Internal Server Error" }
				},
				"security": [
					{
						"BearerAuth": []
					}
				],
				"requestBody": {
					"content": {
						"application/json": {
							"schema": {
								"type": "object",
								"properties": {
									"doctorId": { "example": "any" },
									"patientId": { "example": "any" },
									"date": { "example": "any" },
									"status": { "example": "any" },
									"typeofvisit": { "example": "any" },
									"motive": { "example": "any" },
									"symptoms": { "example": "any" },
									"severity": { "example": "any" },
									"followUpDate": { "example": "any" },
									"diagnosis": { "example": "any" },
									"treatmentPlan": { "example": "any" },
									"notes": { "example": "any" },
									"bloodPressure": { "example": "any" },
									"heartRate": { "example": "any" },
									"respiratoryRate": { "example": "any" },
									"temperature": { "example": "any" },
									"weight": { "example": "any" },
									"systemReview": { "example": "any" },
									"additionalTests": { "example": "any" }
								}
							}
						}
					}
				}
			}
		},
		"/api/records/consultation/{consultationId}": {
			"patch": {
				"tags": ["Consultations"],
				"summary": "Update a consultation record",
				"description": "Roles: doctor. Only the doctor who created the consultation and have access to the patient can update it. Only specific fields can be updated",
				"parameters": [
					{
						"name": "consultationId",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string"
						}
