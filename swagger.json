							}
						}
					}
				}
			}
		},
		"/api/access/patient/requests": {
			"get": {
				"tags": ["Access"],
				"summary": "Patient sees pending access requests",
				"description": "Roles: patient",
				"responses": {
					"200": { "description": "OK" },
					"500": { "description": "Internal Server Error" }
				}
			}
		},
		"/api/access/{id}/respond": {
			"put": {
				"tags": ["Access"],
				"summary": "Patient approves or rejects an access request",
				"description": "Roles: patient",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				],
				"responses": {
					"200": { "description": "OK" },
					"400": { "description": "Bad Request" },
					"403": { "description": "Forbidden" },
					"404": { "description": "Not Found" },
					"500": { "description": "Internal Server Error" }
				},
				"requestBody": {
					"content": {
						"application/json": {
							"schema": {
								"type": "object",
								"properties": {
									"accepted": { "example": "any" }
								}
							}
						}
					}
				}
			}
		},
		"/api/access/doctor/patients": {
			"get": {
				"tags": ["Access"],
				"summary": "Doctor sees approved patients",
				"description": "Roles: doctor",
				"responses": {
					"200": { "description": "OK" },
					"500": { "description": "Internal Server Error" }
				}
			}
		},
		"/api/access/patient/doctors": {
			"get": {
				"tags": ["Access"],
				"summary": "Patient sees approved doctors",
				"description": "Roles: patient",
				"responses": {
					"200": { "description": "OK" },
					"500": { "description": "Internal Server Error" }
				}
			}
		},
		"/api/access/{id}": {
			"delete": {
				"tags": ["Access"],
				"summary": "Patient removes a doctor (deletes access)",
				"description": "Roles: patient",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				],
				"responses": {
					"200": { "description": "OK" },
					"403": { "description": "Forbidden" },
					"404": { "description": "Not Found" },
					"500": { "description": "Internal Server Error" }
				}
			}
		},
		"/auth/register/doctor": {
			"post": {
				"tags": ["Auth"],
				"summary": "Register new doctor",
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"type": "object",
								"required": [
									"firstName",
									"lastName",
									"email",
									"password",
									"licenseNumber"
								],
								"properties": {
									"firstName": { "type": "string" },
									"lastName": { "type": "string" },
									"email": { "type": "string" },
									"password": { "type": "string" },
									"specialization": { "type": "string" },
									"licenseNumber": { "type": "string" },
									"phone": { "type": "string" },
									"cabinetAddress": { "type": "string" }
								}
							}
						}
					}
				},
				"responses": {
					"201": {
						"description": "Doctor registered successfully"
					}
				}
			}
		},
		"/auth/register/patient": {
			"post": {
				"tags": ["Auth"],
				"summary": "Register new patient",
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"type": "object",
								"required": [
									"firstName",
									"lastName",
									"email",
									"password"
								],
								"properties": {
									"firstName": { "type": "string" },
									"lastName": { "type": "string" },
									"email": { "type": "string" },
									"password": { "type": "string" },
									"dateOfBirth": {
										"type": "string",
										"format": "date"
									},
									"gender": {
										"type": "string",
										"enum": ["male", "female"]
									},
									"phone": { "type": "string" },
									"address": { "type": "string" }
								}
							}
						}
					}
				},
				"responses": {
					"201": {
						"description": "Patient registered successfully"
					}
				}
			}
		},
		"/notifications": {
			"get": {
				"tags": ["Notifications"],
				"summary": "User gets notifications",
				"security": [
					{
						"BearerAuth": []
					}
				],
				"responses": {
					"200": { "description": "List of notifications" }
				}
			}
		},
		"/chatbot": {
			"post": {
				"tags": ["Chatbot (AI Agent)"],
				"summary": "Start a new chat with the Medical AI Agent",
				"security": [
					{
						"BearerAuth": []
					}
				],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"type": "object",
								"required": ["prompt"],
								"properties": {
									"prompt": {
										"type": "string",
										"example": "What are the common symptoms of the flu?"
									}
								}
							}
						}
					}
				},
				"responses": {
					"200": {
						"description": "Chat started and response received",
						"content": {
							"application/json": {
								"schema": {
									"type": "object",
									"properties": {
										"success": { "type": "boolean" },
										"thread_id": { "type": "string" },
										"title": { "type": "string" },
										"response": { "type": "string" }
									}
								}
							}
						}
					},
					"400": { "description": "Prompt is required" }
				}
			}
		},
		"/chatbot/{thread_id}": {
			"get": {
				"tags": ["Chatbot (AI Agent)"],
				"summary": "Retrieve chat history by thread ID",
				"security": [
					{
						"BearerAuth": []
					}
				],
				"parameters": [
					{
						"in": "path",
						"name": "thread_id",
						"required": true,
						"schema": { "type": "string" }
					}
				],
				"responses": {
					"200": {
						"description": "Chat history retrieved successfully",
						"content": {
							"application/json": {
								"schema": {
									"type": "object",
									"properties": {
										"success": { "type": "boolean" },
										"thread_id": { "type": "string" },
										"title": { "type": "string" },
										"history": {
											"type": "array",
											"items": {
												"type": "object",
												"properties": {
													"role": {
														"type": "string",
														"enum": [
															"user",
															"assistant"
														]
													},
													"content": {
														"type": "string"
													}
												}
											}
										}
									}
								}
							}
						}
					},
					"404": { "description": "Conversation not found" }
				}
			},
			"post": {
				"tags": ["Chatbot (AI Agent)"],
				"summary": "Continue an existing chat with the Medical AI Agent",
				"security": [
					{
						"BearerAuth": []
					}
				],
				"parameters": [
					{
						"in": "path",
						"name": "thread_id",
						"required": true,
						"schema": { "type": "string" }
					}
				],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"type": "object",
								"required": ["prompt"],
								"properties": {
									"prompt": { "type": "string" }
								}
							}
						}
					}
				},
				"responses": {
					"200": {
						"description": "Response received",
						"content": {
							"application/json": {
								"schema": {
									"type": "object",
									"properties": {
										"success": { "type": "boolean" },
										"thread_id": { "type": "string" },
										"title": { "type": "string" },
										"response": { "type": "string" }
									}
								}
							}
