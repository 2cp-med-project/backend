{
  "definition": {
    "openapi": "3.0.0",
    "info": {
      "title": "Medical Access API",
      "version": "1.0.0",
      "description": "Doctor - Patient Medical Platform with Access Control"
    },
    "servers": [
      {
        "url": "http://localhost:5000/api-docs"
      }
    ],
    "paths": {
      "/auth/register/doctor": {
        "post": {
          "tags": ["Auth"],
          "summary": "Register a user",
          "description": "Register a new patient or doctor. If userType is 'doctor', licenseNumber is required.",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterUser"
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "User registered successfully.",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "message": {
                        "type": "string",
                        "example": "User registered successfully"
                      }
                    }
                  }
                }
              }
            },
            "400": {
              "description": "Missing required fields, invalid user type, or email already registered."
            }
          }
        }
      },
      "/auth/login": {
        "post": {
          "tags": ["Auth"],
          "summary": "Login",
          "description": "Authenticate a patient or doctor and return a refresh token.",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginUser"
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "Login successful. Returns a refresh token.",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "refreshToken": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            },
            "400": {
              "description": "Missing required fields or invalid credentials."
            }
          }
        }
      },
      "/auth/logout": {
        "post": {
          "tags": ["Auth"],
          "summary": "Logout",
          "description": "Log out a user by clearing their stored refresh token.",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "email": {
                      "type": "string"
                    },
                    "userType": {
                      "type": "string",
                      "enum": ["patient", "doctor"]
                    }
                  },
                  "required": ["email", "userType"]
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "Logged out successfully.",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "message": {
                        "type": "string",
                        "example": "Logged out successfully"
                      }
                    }
                  }
                }
              }
            },
            "400": {
              "description": "Missing required fields."
            },
            "404": {
              "description": "Email not found."
            }
          }
        }
      },
      "/auth/refresh-token": {
        "post": {
          "tags": ["Auth"],
          "summary": "Refresh access token",
          "description": "Issue a new short-lived access token using a valid refresh token.",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "refreshToken": {
                      "type": "string"
                    }
                  },
                  "required": ["refreshToken"]
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "New access token issued.",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "accessToken": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            },
            "400": {
              "description": "Missing or invalid refresh token."
            }
          }
        }
      },
      "/auth/verify-otp": {
        "post": {
          "tags": ["Auth"],
          "summary": "Verify OTP",
          "description": "Verify a one-time password sent to the user's email.",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "email": {
                      "type": "string"
                    },
                    "otp": {
                      "type": "string"
                    }
                  },
                  "required": ["email", "otp"]
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "OTP verified successfully."
            },
            "400": {
              "description": "Invalid or expired OTP."
            }
          }
        }
      },
      "/patients/{id}": {
        "get": {
          "summary": "Get patient profile",
          "parameters": [
            {
              "name": "id",
              "in": "path",
              "required": true,
              "schema": {
                "type": "string"
              }
            }
          ],
          "responses": {
            "200": {
              "description": "Patient profile",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/Patient"
                  }
                }
              }
            },
            "404": {
              "description": "Patient not found."
            }
          }
        }
      },
      "/doctors": {
        "get": {
          "summary": "List all doctors",
          "responses": {
            "200": {
              "description": "List of doctors",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/Doctor"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "/medical-card/scan/{cardId}": {
        "get": {
          "summary": "Scan digital health card",
          "parameters": [
            {
              "name": "cardId",
              "in": "path",
              "required": true,
              "schema": {
                "type": "string"
              }
            }
          ],
          "responses": {
            "200": {
              "description": "Patient data retrieved",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/MedicalCardResponse"
                  }
                }
              }
            },
            "404": {
              "description": "Card not found."
            }
          }
        }
      },
      "/ai/specialty": {
        "post": {
          "tags": ["Access"],
          "summary": "Doctor requests access to patient",
          "security": [{ "bearerAuth": [] }],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SymptomRequest"
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "Specialty predicted",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/SpecialtyPrediction"
                  }
                }
              }
            }
          },
          "responses": {
            "200": { "description": "Access updated" }
          }
        }
      }
    },
    "components": {
      "schemas": {
        "RegisterUser": {
          "type": "object",
          "properties": {
            "firstName": {
              "type": "string"
            },
            "lastName": {
              "type": "string"
            },
            "email": {
              "type": "string"
            },
            "password": {
              "type": "string"
            },
            "userType": {
              "type": "string",
              "enum": ["patient", "doctor"]
            },
            "licenseNumber": {
              "type": "string",
              "description": "Required if userType is 'doctor'"
            }
          },
          "required": ["firstName", "lastName", "email", "password", "userType"]
        },
        "LoginUser": {
          "type": "object",
          "properties": {
            "email": {
              "type": "string"
            },
            "password": {
              "type": "string"
            },
            "userType": {
              "type": "string",
              "enum": ["patient", "doctor"]
            }
          },
          "required": ["email", "password", "userType"]
        },
        "Patient": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "fullName": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "Doctor": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "fullName": {
              "type": "string"
            },
            "specialty": {
              "type": "string"
            },
            "location": {
              "type": "string"
            }
          }
        },
        "MedicalCardResponse": {
          "type": "object",
          "properties": {
            "patientId": {
              "type": "string"
            },
            "fullName": {
              "type": "string"
            },
            "age": {
              "type": "number"
            },
            "medicalHistory": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "SymptomRequest": {
          "type": "object",
          "properties": {
            "symptoms": {
              "type": "string"
            }
          },
          "required": ["symptoms"]
        },
        "SpecialtyPrediction": {
          "type": "object",
          "properties": {
            "predictedSpecialty": {
              "type": "string"
            },
            "confidence": {
              "type": "number"
            }
          }
        }
      }
    }
  },
  "apis": ["./src/modules/**/routes.js"]
}
